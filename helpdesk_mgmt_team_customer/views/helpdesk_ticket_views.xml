<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_ticket_form_inherit" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="default_partner_id" invisible="1"/>                
                <field name="allowed_partner_ids" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">
                    ['&amp;',
                        '|',
                            ('id','in',allowed_partner_ids),
                            ('id','=',default_partner_id),
                        '&amp;',
                            ('id','!=',default_partner_id),
                            ('id','not in',allowed_partner_ids)
                    ]
                </attribute>
            </xpath>
        </field>
    </record>

</odoo>
